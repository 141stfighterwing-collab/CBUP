// =============================================================================
// Cyber Brief Unified Platform – Default Schema (SQLite)
// =============================================================================
//
// For MySQL:    cp schema.mysql.prisma schema.prisma && bunx prisma generate
// For PostgreSQL: cp schema.postgresql.prisma schema.prisma && bunx prisma generate
//
// After swapping, run: prisma db push   (or prisma migrate dev)
//
// The runtime provider is selected via DATABASE_PROVIDER env var in db-provider.ts.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  company   String?
  tier      String   @default("free")
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id          String   @id @default(cuid())
  title       String
  severity    String
  source      String
  description String
  category    String
  createdAt   DateTime @default(now())
}

model Brief {
  id          String   @id @default(cuid())
  title       String
  volume      Int
  content     String
  publishedAt DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("new")
  priority    String    @default("medium")
  assignee    String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Agent {
  id            String     @id @default(cuid())
  agentId       String     @unique              // Unique agent identifier (GUID from agent)
  hostname      String
  domain        String?
  osName        String
  osVersion     String
  osArch        String?
  manufacturer  String?
  model         String?
  serialNumber  String?
  biosVersion   String?
  cpuModel      String?
  cpuCores      Int?
  totalRamMb    Int?
  macAddresses  String?                         // JSON array
  ipAddresses   String?                         // JSON array
  status        String     @default("online")   // online, offline, warning, critical
  lastSeen      DateTime   @default(now())
  version       String     @default("1.0.0")    // Agent version
  authToken     String?                         // For agent authentication
  telemetry     Telemetry[]
  commands      Command[]
  edrScans      EDRScan[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Telemetry {
  id           String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id])
  cpuPercent   Float?
  memPercent   Float?
  memUsedMb    Float?
  memTotalMb   Float?
  diskReadBps  Float?
  diskWriteBps Float?
  netInBps     Float?
  netOutBps    Float?
  diskFreeGb   Float?
  diskTotalGb  Float?
  activeTcp    Int?
  uptime       Int?                         // seconds
  topCpuProcs  String?                      // JSON array of top processes
  topMemProcs  String?                      // JSON array
  timestamp    DateTime @default(now())

  @@index([agentId, timestamp])
}

model Command {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  type        String                       // RUN_EDR_SCAN, RUN_CUSTOM_SCRIPT, etc.
  payload     String?                      // JSON payload
  status      String   @default("pending") // pending, executing, completed, failed
  result      String?                      // JSON result
  error       String?
  createdAt   DateTime @default(now())
  executedAt  DateTime?
  completedAt DateTime?

  @@index([agentId, status])
}

model EDRScan {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  scanType    String                       // process, service, port, autorun, vulnerability, full
  status      String   @default("running") // running, completed, failed
  findings    String                       // JSON array of findings
  summary     String?                      // JSON summary
  startedAt   DateTime @default(now())
  completedAt DateTime?
  durationMs  Int?
}
